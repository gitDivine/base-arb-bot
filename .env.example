# ═══════════════════════════════════════════
#  Base Flash Loan Arbitrage Bot — .env
# ═══════════════════════════════════════════

# Your MetaMask private key (same wallet as liquidation bot)
PRIVATE_KEY=your_private_key_here

# Deployed ArbBot.sol contract address (deploy via Remix)
CONTRACT_ADDRESS=your_deployed_contract_address

# Alchemy Base endpoints (same Alchemy account as liquidation bot)
BASE_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Telegram alerts (optional — same bot as liquidation bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set true to scan without real trades (safe testing)
DRY_RUN=false

# Set true to see detailed debug logs
DEBUG=false
